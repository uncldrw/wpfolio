---
interface Testimonial {
  name: string;
  role: string;
  quote: string;
  avatar?: string;
}

interface Props {
  title: string;
  testimonials: Testimonial[];
}

const { title, testimonials } = Astro.props;
---

<section class="py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-14 text-center text-4xl font-bold text-gray-900">{title}</h2>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <p class="mb-6 text-gray-600 leading-relaxed">"{t.quote}"</p>
          <div class="flex items-center gap-4">
            {t.avatar ? (
              <img src={t.avatar} alt={t.name} class="h-12 w-12 rounded-full object-cover" />
            ) : (
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-indigo-100 text-indigo-700 font-bold text-lg">
                {t.name.charAt(0)}
              </div>
            )}
            <div>
              <p class="font-semibold text-gray-900">{t.name}</p>
              <p class="text-sm text-gray-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
