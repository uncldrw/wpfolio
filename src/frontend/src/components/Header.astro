<header>
  <div class="header-main">
    <div class="header-content">
      <ul>
        <li>Home</li>
        <li>References</li>
        <li>About Us</li>
      </ul>
    </div>
    <div class="header-bg"></div>
  </div>
</header>

<style is:global>
  :root {
    --header-height: 7rem;
    --header-height--collapsed: 4rem;
  }
</style>

<style lang="scss">
  header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 50;

    .header-main {
      position: relative;

      .header-bg {
        grid-area: 1 / 1;
        border: grey 1px solid;
        border-radius: 0.375rem;
        background: rgba(255, 255, 255, 0.68);
        backdrop-filter: blur(36px) saturate(150%);
        -webkit-backdrop-filter: blur(36px) saturate(150%);
        margin: 1rem 1rem 0;
        position: absolute;
        inset: 0;
        height: var(--header-height);
      }

      .header-content {
        position: absolute;
        inset: 0;
        margin: 1rem 1rem 0;
        z-index: 1;
        height: var(--header-height);
        ul {
          display: flex;
          gap: 2rem;
          height: 100%;
          align-items: center;

          li {
            cursor: pointer;
            font-weight: 500;
            color: #333;
            transition: color 0.2s;
            height: var(--header-height);
            padding: 2.5rem;

            &:hover {
              color: #000;
            }
          }
        }
      }
    }
  }
</style>
