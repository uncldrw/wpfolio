<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function init() {
    const header = document.querySelector<HTMLElement>("header");
    const headerBg = document.querySelector<HTMLElement>(".header-bg");
    const headerContent =
      document.querySelector<HTMLElement>(".header-content");
    const navItems = gsap.utils.toArray<HTMLElement>("header li");

    if (!header || !headerBg || !headerContent || !navItems.length) return;

    // 2. Nav items staggered: padding 2.5rem → 1rem, 100ms nach Header-Start

    let isCollapsed = false;

    // Active-Klasse wenn 2. Section erreicht wird
    const secondSection = document.querySelector<HTMLElement>(
      "main > section:nth-child(2), main > *:nth-child(2)",
    );

    // Resolve CSS-variable / calc() expressions to absolute pixel values so
    // GSAP can interpolate cleanly from the items' current pixel height
    // (avoids snap-to-target on rapid re-triggers).
    const rootStyles = getComputedStyle(document.documentElement);
    const remToPx = parseFloat(rootStyles.fontSize) || 16;
    const parseLen = (value: string) => {
      const v = value.trim();
      if (v.endsWith("rem")) return parseFloat(v) * remToPx;
      if (v.endsWith("px")) return parseFloat(v);
      return parseFloat(v) || 0;
    };
    const headerHeight = parseLen(
      rootStyles.getPropertyValue("--header-height"),
    );
    const headerHeightCollapsed = parseLen(
      rootStyles.getPropertyValue("--header-height--collapsed"),
    );
    const expandedPx = headerHeight + 2 * remToPx;
    const collapsedPx = headerHeightCollapsed;

    if (secondSection) {
      ScrollTrigger.create({
        trigger: secondSection,
        start: "top top",
        onEnter: () => {
          header.classList.add("active");
          gsap.to(headerBg, {
            height: `${collapsedPx}px`,
            duration: 0.5,
            borderRadius: "0rem",
            borderWidth: "0px",
            borderBottomWidth: "1px",
            margin: "0",
            ease: "expo.out",
          });
          navItems.forEach((item, i) => {
            gsap.to(item, {
              duration: 0.3,
              height: `${collapsedPx}px`,
              marginLeft: "2rem",
              ease: "back.out(1.6)",
              overwrite: true,
              delay: 0.1 * i * 0.2,
            });
          });
        },
        onLeaveBack: () => {
          header.classList.remove("active");
          gsap.killTweensOf(navItems);
          gsap.to(headerBg, {
            height: `${headerHeight}px`,
            duration: 0.5,
            borderRadius: "0.375rem",
            borderWidth: "1px",
            margin: "1rem",
            ease: "expo.out",
          });
          gsap.to(navItems, {
            height: `${expandedPx}px`,
            duration: 0.4,
            ease: "back.out(1.6)",
          });
          navItems.forEach((item, i) => {
            gsap.to(item, {
              marginLeft: "4rem",
              duration: 0.4,
              ease: "back.out(1.6)",
              delay: 0.2 * i * 0.2,
            });
          });
        },
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
<header>
  <div class="header-main">
    <div class="header-content">
      <ul>
        <li><span>Home</span></li>
        <li><span>References</span></li>
        <li><span>About Us</span></li>
      </ul>
    </div>
    <div class="header-bg"></div>
  </div>
</header>

