---
/**
 * TimelineSection — Career / Experience / Education Timeline
 */

interface TimelineItem {
  date: string;
  title: string;
  company?: string;
  description?: string;
  type?: 'work' | 'education' | 'project' | 'achievement';
  skills?: string;
  link?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  items: TimelineItem[];
}

const { title, subtitle, items } = Astro.props;

const typeConfig = {
  work: { label: 'Arbeit', color: 'bg-indigo-600', ring: 'ring-indigo-200', icon: '💼' },
  education: { label: 'Bildung', color: 'bg-emerald-600', ring: 'ring-emerald-200', icon: '🎓' },
  project: { label: 'Projekt', color: 'bg-purple-600', ring: 'ring-purple-200', icon: '🚀' },
  achievement: { label: 'Achievement', color: 'bg-amber-500', ring: 'ring-amber-200', icon: '🏆' },
};

function getConfig(type: TimelineItem['type']) {
  return typeConfig[type ?? 'work'] ?? typeConfig.work;
}

function parseSkills(skills?: string): string[] {
  if (!skills) return [];
  return skills.split(',').map((s) => s.trim()).filter(Boolean);
}
---

<section class="py-20 bg-gray-50">
  <div class="mx-auto max-w-4xl px-6">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h2 class="text-4xl font-bold text-gray-900">{title}</h2>
      {subtitle && <p class="mt-4 text-xl text-gray-500">{subtitle}</p>}
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gray-200 md:left-1/2 md:-ml-px" aria-hidden="true" />

      <div class="space-y-10">
        {items.map((item, i) => {
          const cfg = getConfig(item.type);
          const isEven = i % 2 === 0;
          const skills = parseSkills(item.skills);

          return (
            <div class={`relative flex gap-6 md:gap-0 ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <!-- Dot -->
              <div class="absolute left-6 -translate-x-1/2 top-4 z-10 md:left-1/2">
                <div class={`h-8 w-8 rounded-full ${cfg.color} ring-4 ${cfg.ring} flex items-center justify-center text-sm shadow-md`}>
                  <span>{cfg.icon}</span>
                </div>
              </div>

              <!-- Card (left or right side) -->
              <div class={`ml-14 flex-1 md:ml-0 ${isEven ? 'md:mr-10 md:pr-4 md:text-right' : 'md:ml-10 md:pl-4 md:text-left'} md:w-1/2`}>
                <div class="rounded-2xl bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
                  <!-- Date badge -->
                  <span class={`inline-block rounded-full px-3 py-0.5 text-xs font-semibold text-white mb-3 ${cfg.color}`}>
                    {item.date}
                  </span>

                  <!-- Type label -->
                  <span class="ml-2 text-xs text-gray-400 uppercase tracking-wider">
                    {cfg.label}
                  </span>

                  <h3 class="text-lg font-bold text-gray-900 mt-1">
                    {item.link ? (
                      <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-600 transition-colors">
                        {item.title}
                      </a>
                    ) : item.title}
                  </h3>

                  {item.company && (
                    <p class="text-sm font-medium text-indigo-600 mt-0.5">{item.company}</p>
                  )}

                  {item.description && (
                    <p class="mt-3 text-sm text-gray-500 leading-relaxed">{item.description}</p>
                  )}

                  {skills.length > 0 && (
                    <div class={`mt-4 flex flex-wrap gap-2 ${isEven ? 'md:justify-end' : 'md:justify-start'} justify-start`}>
                      {skills.map((skill) => (
                        <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              {/* Spacer for alternating layout */}
              <div class="hidden md:block md:w-1/2" />
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
