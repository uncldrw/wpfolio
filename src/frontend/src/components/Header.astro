<script>
  import { gsap } from "gsap";

  function init() {
    const headerBg = document.querySelector<HTMLElement>(".header-bg");
    const headerContent =
      document.querySelector<HTMLElement>(".header-content");
    const navItems = gsap.utils.toArray<HTMLElement>("header li");

    if (!headerBg || !headerContent || !navItems.length) return;

    const tl = gsap.timeline({
      paused: true,
      defaults: { ease: "power2.out" },
    });
    const tl2 = gsap.timeline({
      paused: true,
      defaults: { ease: "power2.out" },
    });

    tl
      // 1. Hintergrund schrumpft: margin → 0, height → 5rem, border-radius → 0
      .to(
        headerBg,
        {
          marginTop: 0,
          marginLeft: 0,
          marginRight: 0,
          height: "var(--header-height--collapsed)",
          duration: 0.4,
          ease: "power2.inOut",
        },
        0,
      )
      .to(
        headerBg,
        {
          borderRadius: 0,
          duration: 0.4,
          hease: "power2.inOut",
        },
        0,
      )
      .to(
        headerContent,
        {
          height: "var(--header-height--collapsed)",
          duration: 0.4,
          ease: "power2.inOut",
        },
        0,
      )
      .to(
        navItems,
        {
          padding: "1.75rem",
          duration: 0.2,
          stagger: 0.1,
          ease: "power2.out",
          height: "var(--header-height--collapsed)",
        },
        0.1,
      );
    // 2. Nav items staggered: padding 2.5rem → 1rem, 100ms nach Header-Start

    let isCollapsed = false;

    const handleScroll = () => {
      const shouldCollapse = window.scrollY > 10;
      if (shouldCollapse && !isCollapsed) {
        isCollapsed = true;
        tl.play();
      } else if (!shouldCollapse && isCollapsed) {
        isCollapsed = false;
        tl.reverse();
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
<header>
  <div class="header-main">
    <div class="header-content">
      <ul>
        <li>Home</li>
        <li>References</li>
        <li>About Us</li>
      </ul>
    </div>
    <div class="header-bg"></div>
  </div>
</header>

<style is:global>
  :root {
    --header-height: 7rem;
    --header-height--collapsed: 5rem;
  }
</style>

