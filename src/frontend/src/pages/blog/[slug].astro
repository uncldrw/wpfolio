---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CMS_URL } from 'astro:env/server';

const { slug } = Astro.params;

interface Post {
  id: number;
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: string;
  coverImage?: { url: string; alt?: string } | null;
  content?: unknown;
  seo?: {
    title?: string;
    description?: string;
    noindex?: boolean;
  };
}

let post: Post | null = null;

try {
  const res = await fetch(
    `${CMS_URL}/api/posts?where[slug][equals]=${slug}&where[status][equals]=published&depth=1&limit=1`
  );
  if (res.ok) {
    const data = await res.json();
    post = data.docs?.[0] ?? null;
  }
} catch {
  // CMS unavailable
}

if (!post) {
  return Astro.redirect('/blog', 302);
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout
  title={post.seo?.title ?? `${post.title} — Jason Hoang`}
  description={post.seo?.description ?? post.excerpt ?? ''}
>
  <article class="py-20 bg-white">
    <div class="mx-auto max-w-3xl px-6">
      <!-- Back -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-indigo-700 transition-colors mb-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Alle Artikel
      </a>

      <!-- Header -->
      <header class="mb-10">
        {post.publishedAt && (
          <time class="text-sm text-gray-400" datetime={post.publishedAt}>
            {formatDate(post.publishedAt)}
          </time>
        )}
        <h1 class="mt-2 text-4xl font-bold text-gray-900 leading-tight">{post.title}</h1>
        {post.excerpt && (
          <p class="mt-4 text-xl text-gray-500 leading-relaxed">{post.excerpt}</p>
        )}
      </header>

      <!-- Cover Image -->
      {post.coverImage?.url && (
        <div class="mb-10 overflow-hidden rounded-2xl aspect-video">
          <img
            src={post.coverImage.url}
            alt={post.coverImage.alt ?? post.title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-gray prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-p:text-gray-600 prose-p:leading-relaxed
        prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline
        prose-code:text-indigo-700 prose-code:bg-indigo-50 prose-code:px-1 prose-code:rounded
        prose-pre:bg-gray-900 prose-pre:text-gray-100">
        <slot />
        {/* Rich text wird vom CMS als HTML gerendert — für jetzt Plaintext-Fallback */}
        {typeof post.content === 'string' && (
          <div set:html={post.content} />
        )}
        {!post.content && (
          <p class="text-gray-400 italic">Kein Inhalt verfügbar.</p>
        )}
      </div>

      <!-- Footer -->
      <div class="mt-16 pt-8 border-t border-gray-100 flex items-center justify-between">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Alle Artikel
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center gap-2 rounded-full bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700 transition"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
