---
/**
 * Footer Component — mehrspaltig, CMS-gesteuert
 * Fetches footer config from Payload CMS `menus` collection (identifier: "footer").
 */

import { CMS_URL } from 'astro:env/server';

interface NavItem {
  label: string;
  url: string;
  openInNewTab?: boolean;
}

interface FooterColumn {
  heading: string;
  links: { label: string; url: string; openInNewTab?: boolean }[];
}

interface SocialLink {
  icon: string;
  url: string;
  label: string;
}

interface FooterMenu {
  copyright?: string;
  tagline?: string;
  socialLinks?: SocialLink[];
  columns?: FooterColumn[];
  items?: NavItem[];
}

let footerData: FooterMenu = {};

try {
  const res = await fetch(`${CMS_URL}/api/menus?where[identifier][equals]=footer&limit=1`);
  if (res.ok) {
    const data = await res.json();
    const menu = data.docs?.[0];
    if (menu) {
      footerData = {
        copyright: menu.copyright,
        tagline: menu.tagline,
        socialLinks: menu.socialLinks ?? [],
        columns: menu.columns ?? [],
        items: menu.items ?? [],
      };
    }
  }
} catch {
  // CMS unavailable
}

const year = new Date().getFullYear();
const copyright = footerData.copyright ?? `© ${year} Jason Hoang. Alle Rechte vorbehalten.`;
const columns = footerData.columns ?? [];
---

<footer class="bg-gray-900 text-gray-300 pt-16 pb-6 mt-auto">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Top section: Brand + Columns + Social -->
    <div class={`grid gap-10 mb-12 ${columns.length > 0 ? 'md:grid-cols-[1fr_auto] lg:grid-cols-[1fr_auto_auto]' : 'md:grid-cols-[1fr_auto]'}`}>

      <!-- Brand -->
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white tracking-tight mb-3" aria-label="Zur Startseite">
          <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="28" height="28" rx="8" fill="#4F46E5"/>
            <path d="M8 20L14 8L20 20" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 16H18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          wpfolio
        </a>
        {footerData.tagline ? (
          <p class="text-sm text-gray-400 leading-relaxed">{footerData.tagline}</p>
        ) : (
          <p class="text-sm text-gray-400 leading-relaxed">
            Full-Stack Development aus Düsseldorf — modern, schnell, skalierbar.
          </p>
        )}

        <!-- Social Links -->
        {footerData.socialLinks && footerData.socialLinks.length > 0 && (
          <div class="flex items-center gap-3 mt-5">
            {footerData.socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-800 hover:bg-indigo-600 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-500"
              >
                <span class="text-sm" aria-hidden="true">{social.icon}</span>
              </a>
            ))}
          </div>
        )}
        {(!footerData.socialLinks || footerData.socialLinks.length === 0) && (
          <div class="flex items-center gap-3 mt-5">
            <a href="https://github.com/uncldrw" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-800 hover:bg-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-800 hover:bg-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        )}
      </div>

      <!-- Footer Columns (CMS-gesteuert) -->
      {columns.length > 0 && columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{col.heading}</h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.url}
                  target={link.openInNewTab ? '_blank' : undefined}
                  rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Fallback wenn keine CMS-Columns: statische Links -->
      {columns.length === 0 && (
        <>
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Navigation</h3>
            <ul class="space-y-2.5">
              <li><a href="/" class="text-sm text-gray-400 hover:text-white transition-colors">Home</a></li>
              <li><a href="/#projects-gallery" class="text-sm text-gray-400 hover:text-white transition-colors">Projekte</a></li>
              <li><a href="/blog" class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
              <li><a href="/kontakt" class="text-sm text-gray-400 hover:text-white transition-colors">Kontakt</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Services</h3>
            <ul class="space-y-2.5">
              <li><a href="/kontakt" class="text-sm text-gray-400 hover:text-white transition-colors">Web-Entwicklung</a></li>
              <li><a href="/kontakt" class="text-sm text-gray-400 hover:text-white transition-colors">API-Entwicklung</a></li>
              <li><a href="/kontakt" class="text-sm text-gray-400 hover:text-white transition-colors">DevOps & Deployment</a></li>
            </ul>
          </div>
        </>
      )}
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500">{copyright}</p>
      <nav class="flex gap-5" aria-label="Legal navigation">
        <a href="/impressum" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Impressum</a>
        <a href="/datenschutz" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>
