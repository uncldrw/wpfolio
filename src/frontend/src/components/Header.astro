<script>
  function observeSecondSection() {
    const headerMain = document.querySelector(".header-main");
    const sections = document.querySelectorAll("section");
    const secondSection = sections[1];

    if (!headerMain || !secondSection) return;

    // rootMargin only accepts px or %, not rem — resolve --header-height to px
    const rootEl = document.documentElement;
    const headerHeightRaw = getComputedStyle(rootEl)
      .getPropertyValue("--header-height")
      .trim();
    const rootFontSize = parseFloat(getComputedStyle(rootEl).fontSize) || 16;
    let headerHeightPx = 0;
    if (headerHeightRaw.endsWith("rem")) {
      headerHeightPx = parseFloat(headerHeightRaw) * rootFontSize;
    } else if (headerHeightRaw.endsWith("em")) {
      headerHeightPx = parseFloat(headerHeightRaw) * rootFontSize;
    } else if (headerHeightRaw.endsWith("px")) {
      headerHeightPx = parseFloat(headerHeightRaw);
    } else {
      headerHeightPx = parseFloat(headerHeightRaw) || 64;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        headerMain.classList.toggle("active", entry.isIntersecting);
      },
      {
        // fire when the second section reaches the header height
        rootMargin: `-${headerHeightPx}px 0px 0px 0px`,
        threshold: 0,
      },
    );

    observer.observe(secondSection);
  }

  // Wait for DOM to be fully ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", observeSecondSection);
  } else {
    observeSecondSection();
  }
</script>

<header>
  <div class="header-main">
    <ul>
      <li>Home</li>
      <li>References</li>
      <li>About Us</li>
    </ul>
  </div>
</header>

<style is:global>
  :root {
    --header-height: 4rem;
  }
</style>

<style lang="scss">
  header {
    position: fixed;
    top: 0;
    height: var(--header-height);
    width: 100%;
    z-index: 50;
  }

  .header-main.active {
  }

  .header-main {
    margin: 1rem 1rem 0;
    border: grey 1px solid;
    border-radius: 0.375rem;
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(36px) saturate(150%);
    -webkit-backdrop-filter: blur(36px) saturate(150%);
  }
</style>
