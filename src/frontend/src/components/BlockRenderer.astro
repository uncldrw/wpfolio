---
import HeroSection from './blocks/HeroSection.astro';
import AboutSection from './blocks/AboutSection.astro';
import FeaturesSection from './blocks/FeaturesSection.astro';
import TestimonialsSection from './blocks/TestimonialsSection.astro';
import CtaSection from './blocks/CtaSection.astro';
import PricingSection from './blocks/PricingSection.astro';
import StatsSection from './blocks/StatsSection.astro';
import LogoBandSection from './blocks/LogoBandSection.astro';
import ProjectsGallerySection from './blocks/ProjectsGallerySection.astro';
import ProjectSliderSection from './blocks/ProjectSliderSection.astro';
import SkillsSection from './blocks/SkillsSection.astro';
import TimelineSection from './blocks/TimelineSection.astro';
import ServicesSection from './blocks/ServicesSection.astro';

type Variant = 'primary' | 'secondary' | 'dark';

interface HeroBlock {
  blockType: 'hero';
  headline: string;
  subheadline: string;
  ctaLabel: string;
  ctaLink: string;
  backgroundImage?: string;
}

interface AboutBlock {
  blockType: 'about';
  title: string;
  content: string;
  image?: string;
  imagePosition?: 'left' | 'right';
}

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface FeaturesBlock {
  blockType: 'features';
  title: string;
  subtitle?: string;
  features: Feature[];
}

interface Testimonial {
  name: string;
  role: string;
  quote: string;
  avatar?: string;
}

interface TestimonialsBlock {
  blockType: 'testimonials';
  title: string;
  testimonials: Testimonial[];
}

interface CtaBlock {
  blockType: 'cta';
  headline: string;
  subheadline?: string;
  buttonLabel: string;
  buttonLink: string;
  variant?: Variant;
}

interface PricingFeature {
  label: string;
  included: boolean;
}

interface PricingTier {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features: PricingFeature[];
  ctaLabel: string;
  ctaLink: string;
  highlighted?: boolean;
}

interface PricingBlock {
  blockType: 'pricing';
  title: string;
  subtitle?: string;
  tiers: PricingTier[];
}

interface Stat {
  value: string;
  label: string;
  description?: string;
}

interface StatsBlock {
  blockType: 'stats';
  title?: string;
  subtitle?: string;
  stats: Stat[];
  variant?: 'light' | 'dark' | 'indigo';
}

interface LogoItem {
  name: string;
  logo: { url: string; alt?: string } | string;
  url?: string;
}

interface LogoBandBlock {
  blockType: 'logoBand';
  title?: string;
  logos: LogoItem[];
}

interface ProjectTag {
  tag: string;
}

interface GalleryProject {
  title: string;
  description?: string;
  image: { url: string; alt?: string } | string;
  category?: string;
  tags?: ProjectTag[];
  link?: string;
  githubLink?: string;
  featured?: boolean;
}

interface ProjectsGalleryBlock {
  blockType: 'projectsGallery';
  title: string;
  subtitle?: string;
  showFilters?: boolean;
  projects: GalleryProject[];
}

interface SliderSlide {
  title: string;
  description?: string;
  image: { url: string; alt?: string } | string;
  category?: string;
  year?: string;
  ctaLabel?: string;
  ctaLink?: string;
  tags?: ProjectTag[];
}

interface ProjectSliderBlock {
  blockType: 'projectSlider';
  title: string;
  subtitle?: string;
  autoplay?: boolean;
  slides: SliderSlide[];
}

interface SkillItem {
  name: string;
  level?: number;
  icon?: string;
  logo?: { url: string; alt?: string } | string;
}

interface SkillGroup {
  groupName: string;
  skills: SkillItem[];
}

interface SkillsBlock {
  blockType: 'skills';
  title: string;
  subtitle?: string;
  layout?: 'grid' | 'bubbles' | 'icons';
  skillGroups: SkillGroup[];
}

interface TimelineItem {
  date: string;
  title: string;
  company?: string;
  description?: string;
  type?: 'work' | 'education' | 'project' | 'achievement';
  skills?: string;
  link?: string;
}

interface TimelineBlock {
  blockType: 'timeline';
  title: string;
  subtitle?: string;
  items: TimelineItem[];
}

interface Highlight {
  point: string;
}

interface ServiceItem {
  icon?: string;
  title: string;
  description: string;
  highlights?: Highlight[];
  highlighted?: boolean;
  ctaLabel?: string;
  ctaLink?: string;
}

interface ServicesBlock {
  blockType: 'services';
  title: string;
  subtitle?: string;
  layout?: 'cards' | 'list' | 'split';
  ctaLabel?: string;
  ctaLink?: string;
  services: ServiceItem[];
}

type Block =
  | HeroBlock
  | AboutBlock
  | FeaturesBlock
  | TestimonialsBlock
  | CtaBlock
  | PricingBlock
  | StatsBlock
  | LogoBandBlock
  | ProjectsGalleryBlock
  | ProjectSliderBlock
  | SkillsBlock
  | TimelineBlock
  | ServicesBlock;

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;

// Helper: resolve media object (Payload returns { url, ... } or just a string)
function resolveMedia(val: unknown): string {
  if (!val) return '';
  if (typeof val === 'string') return val;
  if (typeof val === 'object' && val !== null && 'url' in val) return (val as { url: string }).url ?? '';
  return '';
}

// Normalize LogoBand logos: map Payload upload field to src
function normalizeLogo(logo: LogoItem) {
  return {
    name: logo.name,
    src: resolveMedia(logo.logo),
    url: logo.url,
  };
}
---

{blocks.map((block) => {
  if (block.blockType === 'hero') {
    return <HeroSection {...block} backgroundImage={resolveMedia(block.backgroundImage)} />;
  }
  if (block.blockType === 'about') {
    return <AboutSection {...block} />;
  }
  if (block.blockType === 'features') {
    return <FeaturesSection {...block} />;
  }
  if (block.blockType === 'testimonials') {
    return <TestimonialsSection {...block} />;
  }
  if (block.blockType === 'cta') {
    return <CtaSection {...block} />;
  }
  if (block.blockType === 'pricing') {
    return <PricingSection {...block} />;
  }
  if (block.blockType === 'stats') {
    return <StatsSection {...block} />;
  }
  if (block.blockType === 'logoBand') {
    const normalizedLogos = block.logos.map(normalizeLogo);
    return <LogoBandSection title={block.title} logos={normalizedLogos} />;
  }
  if (block.blockType === 'projectsGallery') {
    return <ProjectsGallerySection {...block} />;
  }
  if (block.blockType === 'projectSlider') {
    return <ProjectSliderSection {...block} />;
  }
  if (block.blockType === 'skills') {
    return <SkillsSection {...block} />;
  }
  if (block.blockType === 'timeline') {
    return <TimelineSection {...block} />;
  }
  if (block.blockType === 'services') {
    return <ServicesSection {...block} />;
  }
  return null;
})}
