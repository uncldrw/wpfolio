---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features } = Astro.props;
---

<section class="bg-gray-50 py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <h2 class="text-4xl font-bold text-gray-900">{title}</h2>
      {subtitle && <p class="mt-4 text-xl text-gray-500">{subtitle}</p>}
    </div>
    <div class="grid gap-8 md:grid-cols-3">
      {features.map((feature) => (
        <div class="rounded-2xl bg-white p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-5 text-4xl">{feature.icon}</div>
          <h3 class="mb-3 text-xl font-semibold text-gray-900">{feature.title}</h3>
          <p class="text-gray-500 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
