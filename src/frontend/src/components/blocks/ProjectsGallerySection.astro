---
/**
 * ProjectsGallery — filterable project grid with category filters
 */

interface Tag {
  tag: string;
  id?: string;
}

interface Project {
  title: string;
  description?: string;
  image: { url: string; alt?: string } | string;
  category?: string;
  tags?: Tag[];
  link?: string;
  githubLink?: string;
  featured?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  showFilters?: boolean;
  projects: Project[];
}

const { title, subtitle, showFilters = true, projects } = Astro.props;

// Collect unique categories
const categories = ['Alle', ...Array.from(new Set(projects.map((p) => p.category).filter(Boolean) as string[]))];

function getImageUrl(image: Project['image']): string {
  if (!image) return '';
  if (typeof image === 'string') return image;
  return image.url ?? '';
}
function getImageAlt(image: Project['image'], title: string): string {
  if (!image || typeof image === 'string') return title;
  return (image as { url: string; alt?: string }).alt ?? title;
}
---

<section class="py-20 bg-gray-50" id="projects-gallery">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Header -->
    <div class="mb-12 text-center">
      <h2 class="text-4xl font-bold text-gray-900">{title}</h2>
      {subtitle && <p class="mt-4 text-xl text-gray-500">{subtitle}</p>}
    </div>

    <!-- Category Filters -->
    {showFilters && categories.length > 1 && (
      <div class="mb-10 flex flex-wrap justify-center gap-3" id="gallery-filters">
        {categories.map((cat) => (
          <button
            class={`gallery-filter-btn rounded-full px-5 py-2 text-sm font-medium transition-all ${cat === 'Alle' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-gray-600 border border-gray-200 hover:border-indigo-400 hover:text-indigo-600'}`}
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
      {projects.map((project) => (
        <div
          class="gallery-item group relative overflow-hidden rounded-2xl bg-white shadow-sm hover:shadow-xl transition-all duration-300"
          data-category={project.category ?? 'Alle'}
        >
          <!-- Image -->
          <div class="relative overflow-hidden aspect-[4/3]">
            <img
              src={getImageUrl(project.image)}
              alt={getImageAlt(project.image, project.title)}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            {project.featured && (
              <span class="absolute top-3 left-3 rounded-full bg-indigo-600 px-3 py-1 text-xs font-semibold text-white shadow">
                Featured
              </span>
            )}
            {project.category && (
              <span class="absolute top-3 right-3 rounded-full bg-black/50 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                {project.category}
              </span>
            )}
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-indigo-900/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-4">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full bg-white px-5 py-2 text-sm font-semibold text-indigo-900 hover:bg-indigo-50 transition"
                >
                  Live ansehen →
                </a>
              )}
              {project.githubLink && (
                <a
                  href={project.githubLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full border border-white px-5 py-2 text-sm font-semibold text-white hover:bg-white/10 transition"
                >
                  GitHub
                </a>
              )}
            </div>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="text-lg font-semibold text-gray-900">{project.title}</h3>
            {project.description && (
              <p class="mt-2 text-sm text-gray-500 line-clamp-2">{project.description}</p>
            )}
            {project.tags && project.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {project.tags.map((t) => (
                  <span class="rounded-full bg-indigo-50 px-3 py-0.5 text-xs font-medium text-indigo-700">
                    {t.tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="gallery-empty" class="hidden py-20 text-center text-gray-400">
      Keine Projekte in dieser Kategorie.
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.gallery-filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  const empty = document.getElementById('gallery-empty');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'Alle';

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-indigo-600', 'text-white', 'shadow-md');
        b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      });
      btn.classList.add('bg-indigo-600', 'text-white', 'shadow-md');
      btn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');

      // Filter items
      let visible = 0;
      items.forEach((item) => {
        const cat = item.dataset.category ?? '';
        const show = filter === 'Alle' || cat === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (empty) empty.classList.toggle('hidden', visible > 0);
    });
  });
</script>
