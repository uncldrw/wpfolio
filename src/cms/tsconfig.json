{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@payload-config": ["./src/payload.config.ts"]
    }
  },
  "include": ["src/**/*", "next.config.mjs"],
  "exclude": ["node_modules"]
}
