---
/**
 * ProjectSlider — Swiper.js carousel for featured projects (npm package)
 */
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

interface Tag {
  tag: string;
  id?: string;
}

interface Slide {
  title: string;
  description?: string;
  image: { url: string; alt?: string } | string | null;
  category?: string;
  year?: string;
  ctaLabel?: string;
  ctaLink?: string;
  tags?: Tag[];
}

interface Props {
  title: string;
  subtitle?: string;
  autoplay?: boolean;
  slides: Slide[];
}

const { title, subtitle, autoplay = false, slides } = Astro.props;

const sliderId = `swiper-${Math.random().toString(36).slice(2, 8)}`;

function getImageUrl(image: Slide['image']): string {
  if (!image) return '';
  if (typeof image === 'string') return image;
  return image.url ?? '';
}
function getImageAlt(image: Slide['image'], fallback: string): string {
  if (!image || typeof image === 'string') return fallback;
  return (image as { url: string; alt?: string }).alt ?? fallback;
}
---

<section class="py-20 bg-white overflow-hidden" id="project-slider">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Header -->
    <div class="mb-12 text-center">
      <h2 class="text-4xl font-bold text-gray-900">{title}</h2>
      {subtitle && <p class="mt-4 text-xl text-gray-500">{subtitle}</p>}
    </div>

    <!-- Swiper -->
    <div class={`swiper ${sliderId}`} id={sliderId} data-autoplay={autoplay ? 'true' : 'false'}>
      <div class="swiper-wrapper pb-12">
        {slides.map((slide) => (
          <div class="swiper-slide">
            <div class="group relative overflow-hidden rounded-2xl bg-gray-50 shadow-md hover:shadow-xl transition-shadow duration-300">
              <!-- Image -->
              {getImageUrl(slide.image) && (
                <div class="relative overflow-hidden aspect-video">
                  <img
                    src={getImageUrl(slide.image)}
                    alt={getImageAlt(slide.image, slide.title)}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  {(slide.category || slide.year) && (
                    <div class="absolute top-4 left-4 flex gap-2">
                      {slide.category && (
                        <span class="rounded-full bg-indigo-600/90 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                          {slide.category}
                        </span>
                      )}
                      {slide.year && (
                        <span class="rounded-full bg-black/50 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                          {slide.year}
                        </span>
                      )}
                    </div>
                  )}
                </div>
              )}

              <!-- Content -->
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900">{slide.title}</h3>
                {slide.description && (
                  <p class="mt-2 text-gray-500 leading-relaxed line-clamp-3">{slide.description}</p>
                )}
                {slide.tags && slide.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {slide.tags.map((t) => (
                      <span class="rounded-full bg-indigo-50 px-3 py-0.5 text-xs font-medium text-indigo-700">
                        {t.tag}
                      </span>
                    ))}
                  </div>
                )}
                {slide.ctaLabel && slide.ctaLink && (
                  <div class="mt-5">
                    <a
                      href={slide.ctaLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-full bg-indigo-600 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition"
                    >
                      {slide.ctaLabel}
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Pagination -->
      <div class="swiper-pagination"></div>

      <!-- Navigation -->
      <div class="swiper-button-prev !text-indigo-600 !w-10 !h-10 !bg-white !shadow-md !rounded-full after:!text-base" aria-label="Vorheriges Slide"></div>
      <div class="swiper-button-next !text-indigo-600 !w-10 !h-10 !bg-white !shadow-md !rounded-full after:!text-base" aria-label="Nächstes Slide"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';

  // Init all sliders on the page (support multiple instances)
  document.querySelectorAll<HTMLElement>('.swiper[id^="swiper-"]').forEach((el) => {
    const autoplayEnabled = el.dataset.autoplay === 'true';
    new Swiper(el, {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      grabCursor: true,
      pagination: {
        el: el.querySelector('.swiper-pagination') as HTMLElement,
        clickable: true,
      },
      navigation: {
        nextEl: el.querySelector('.swiper-button-next') as HTMLElement,
        prevEl: el.querySelector('.swiper-button-prev') as HTMLElement,
      },
      autoplay: autoplayEnabled ? { delay: 4000, disableOnInteraction: false } : false,
      breakpoints: {
        640: { slidesPerView: 1.5 },
        1024: { slidesPerView: 2.5 },
      },
    });
  });
</script>
