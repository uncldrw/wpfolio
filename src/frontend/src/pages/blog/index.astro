---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CMS_URL } from 'astro:env/server';

interface Post {
  id: number;
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: string;
  coverImage?: { url: string; alt?: string } | null;
  status: string;
}

let posts: Post[] = [];
let totalDocs = 0;

try {
  const res = await fetch(
    `${CMS_URL}/api/posts?where[status][equals]=published&sort=-publishedAt&limit=12&depth=1`
  );
  if (res.ok) {
    const data = await res.json();
    posts = data.docs ?? [];
    totalDocs = data.totalDocs ?? 0;
  }
} catch {
  // CMS unavailable
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout
  title="Blog — Jason Hoang"
  description="Artikel über Web-Entwicklung, TypeScript, Astro, Docker und mehr von Jason Hoang."
>
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-6xl px-6">
      <!-- Header -->
      <div class="mb-14 max-w-2xl">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Blog</h1>
        <p class="text-xl text-gray-500 leading-relaxed">
          Artikel über Web-Entwicklung, TypeScript, Astro, Docker und alles was mich gerade
          beschäftigt.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-20 text-gray-400">
          <p class="text-lg">Noch keine Artikel veröffentlicht.</p>
          <p class="text-sm mt-2">Schau bald nochmal vorbei!</p>
        </div>
      ) : (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <article class="group flex flex-col bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <!-- Cover Image -->
              {post.coverImage?.url && (
                <a href={`/blog/${post.slug}`} class="block overflow-hidden aspect-video">
                  <img
                    src={post.coverImage.url}
                    alt={post.coverImage.alt ?? post.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              )}

              {/* Placeholder wenn kein Bild */}
              {!post.coverImage?.url && (
                <a href={`/blog/${post.slug}`} class="block overflow-hidden aspect-video bg-gradient-to-br from-indigo-50 to-indigo-100 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </a>
              )}

              <!-- Content -->
              <div class="flex flex-col flex-1 p-6">
                {post.publishedAt && (
                  <time class="text-xs text-gray-400 mb-2" datetime={post.publishedAt}>
                    {formatDate(post.publishedAt)}
                  </time>
                )}
                <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-indigo-700 transition-colors line-clamp-2">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                {post.excerpt && (
                  <p class="text-sm text-gray-500 leading-relaxed line-clamp-3 flex-1">
                    {post.excerpt}
                  </p>
                )}
                <a
                  href={`/blog/${post.slug}`}
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors"
                  aria-label={`Artikel lesen: ${post.title}`}
                >
                  Weiterlesen
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

      {totalDocs > 12 && (
        <div class="mt-12 text-center">
          <p class="text-sm text-gray-400">{totalDocs} Artikel insgesamt</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
